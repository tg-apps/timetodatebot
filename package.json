{
  "name": "timetodatebot",
  "private": true,
  "type": "module",
  "imports": {
    "#constants": "./src/constants.ts",
    "#db": "./src/db/index.ts",
    "#db/schema": "./src/db/schema.ts",
    "#handlers": "./src/handlers/index.ts",
    "#handlers/*": "./src/handlers/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#utils": "./src/lib/utils.ts",
    "#schemas": "./src/schemas/index.ts"
  },
  "scripts": {
    "test": "DB_FILE_NAME='' bun test",
    "format": "oxfmt",
    "lint": "oxlint",
    "dev": "NODE_ENV=development bun run ./src/index.ts",
    "build": "NODE_ENV=production bun build --minify --compile ./src/index.ts --outfile=dist/bot --target=bun-linux-arm64"
  },
  "dependencies": {
    "@grammyjs/runner": "2.0.3",
    "drizzle-orm": "0.45.2",
    "grammy": "1.43.0",
    "minizod": "0.0.3"
  },
  "devDependencies": {
    "@gameroman/config": "0.2.2",
    "@types/bun": "1.3.14",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3"
  }
}
