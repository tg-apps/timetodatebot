{
  "name": "timetodatebot",
  "private": true,
  "type": "module",
  "imports": {
    "#constants": "./src/constants.ts",
    "#db": "./src/db/index.ts",
    "#db/schema": "./src/db/schema.ts",
    "#lib/*": "./src/lib/*.ts",
    "#utils": "./src/lib/utils.ts",
    "#schemas": "./src/schemas/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "format": "oxfmt --list-different || oxfmt",
    "lint": "oxlint",
    "dev": "NODE_ENV=development bun run ./src/index.ts",
    "build": "NODE_ENV=production bun build --minify --compile ./src/index.ts --outfile=dist/bot --target=bun-linux-arm64"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.41.1",
    "minizod": "^0.0.3"
  },
  "devDependencies": {
    "@gameroman/config": "^0.0.3",
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "typescript": "^5.9.3"
  }
}
